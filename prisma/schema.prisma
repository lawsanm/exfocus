// Prisma schema for exfocus — Smart Study Planner.
// See docs/architecture notes in the repo for the reasoning behind the
// scheduling-related models (StudySession, FocusSession).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth) — standard Prisma adapter shape, extended with the
// app's own profile/gamification fields directly on User.
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for OAuth-only accounts

  // Profile (Feature 17)
  university      String?
  degree          String?
  semester        String?
  academicYear    String?
  currentGpa      Float?
  targetGpa       Float?
  weeklyGoalHours Float   @default(10)
  dailyGoalHours  Float   @default(2)
  timezone        String  @default("UTC")

  // Gamification (Feature 10)
  xp            Int       @default(0)
  level         Int       @default(1)
  coins         Int       @default(0)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastStudyDate DateTime?

  // Settings (Feature 16)
  theme            Theme     @default(SYSTEM)
  defaultFocusMode FocusMode @default(POMODORO_25_5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts               Account[]
  sessions               Session[]
  subjects               Subject[]
  assignments            Assignment[]
  exams                  Exam[]
  quizzes                Quiz[]
  projects               Project[]
  studyGoals             StudyGoal[]
  availableHours         AvailableHours[]
  studySessions          StudySession[]
  focusSessions          FocusSession[]
  notifications          Notification[]
  achievements           UserAchievement[]
  notificationPreference NotificationPreference?

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Shared enums
// ---------------------------------------------------------------------------

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  VERY_HARD
}

enum PriorityLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum StudySessionSource {
  AUTO_GENERATED
  MANUAL
}

enum StudySessionStatus {
  PLANNED
  COMPLETED
  SKIPPED
  RESCHEDULED
}

enum RelatedItemType {
  SUBJECT
  ASSIGNMENT
  EXAM
  QUIZ
  PROJECT
  GENERAL
}

enum FocusMode {
  POMODORO_25_5
  DEEP_FOCUS_50_10
  SESSION_90
  CUSTOM
}

enum StudyGoalType {
  WEEKLY_HOURS
  SUBJECT_COMPLETION
  CUSTOM
}

enum NotificationType {
  STUDY_REMINDER
  EXAM_ALERT
  ASSIGNMENT_ALERT
  DAILY_SUMMARY
  WEEKLY_SUMMARY
  STREAK_REMINDER
  ACHIEVEMENT_UNLOCKED
  RISK_WARNING
}

// ---------------------------------------------------------------------------
// Academic entities (Feature 1)
// ---------------------------------------------------------------------------

model Subject {
  id                 String     @id @default(cuid())
  userId             String
  name               String
  difficulty         Difficulty @default(MEDIUM)
  creditHours        Float      @default(3)
  targetGrade        String?
  preparationPercent Int        @default(0)
  estimatedHours     Float      @default(0)
  colorHex           String     @default("#0D9488")
  archivedAt         DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics        SubjectTopic[]
  assignments   Assignment[]
  exams         Exam[]
  quizzes       Quiz[]
  projects      Project[]
  studyGoals    StudyGoal[]
  studySessions StudySession[]
  focusSessions FocusSession[]

  @@index([userId])
  @@index([userId, archivedAt])
}

model SubjectTopic {
  id             String   @id @default(cuid())
  subjectId      String
  name           String
  estimatedHours Float    @default(1)
  completed      Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
}

model Assignment {
  id              String     @id @default(cuid())
  userId          String
  subjectId       String
  title           String
  deadline        DateTime
  difficulty      Difficulty @default(MEDIUM)
  weight          Int        @default(10) // % of subject grade
  estimatedHours  Float      @default(2)
  progressPercent Int        @default(0)
  status          TaskStatus @default(NOT_STARTED)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  studySessions StudySession[]
  focusSessions FocusSession[]

  @@index([userId])
  @@index([userId, deadline])
  @@index([subjectId])
}

model Exam {
  id                 String     @id @default(cuid())
  userId             String
  subjectId          String
  date               DateTime
  weight             Int        @default(20)
  difficulty         Difficulty @default(MEDIUM)
  preparationPercent Int        @default(0)
  estimatedHours     Float      @default(4)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topics        ExamTopic[]
  studySessions StudySession[]
  focusSessions FocusSession[]

  @@index([userId])
  @@index([userId, date])
  @@index([subjectId])
}

model ExamTopic {
  id        String   @id @default(cuid())
  examId    String
  name      String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model Quiz {
  id                 String     @id @default(cuid())
  userId             String
  subjectId          String
  quizDate           DateTime
  difficulty         Difficulty @default(MEDIUM)
  weight             Int        @default(5)
  estimatedHours     Float      @default(1)
  preparationPercent Int        @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  studySessions StudySession[]
  focusSessions FocusSession[]

  @@index([userId])
  @@index([userId, quizDate])
  @@index([subjectId])
}

model Project {
  id              String   @id @default(cuid())
  userId          String
  subjectId       String?
  title           String
  deadline        DateTime
  progressPercent Int      @default(0)
  estimatedHours  Float    @default(6)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       Subject?       @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  studySessions StudySession[]
  focusSessions FocusSession[]

  @@index([userId])
  @@index([userId, deadline])
  @@index([subjectId])
}

model StudyGoal {
  id          String        @id @default(cuid())
  userId      String
  subjectId   String?
  type        StudyGoalType @default(WEEKLY_HOURS)
  description String
  targetHours Float?
  deadline    DateTime?
  achieved    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// One row per weekday per user — the recurring "available hours" template
// the scheduling engine allocates against.
model AvailableHours {
  id        String   @id @default(cuid())
  userId    String
  dayOfWeek Int // 0 = Sunday .. 6 = Saturday
  hours     Float    @default(2)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek])
}

// ---------------------------------------------------------------------------
// Scheduling engine output + execution tracking (Features 2-6)
// ---------------------------------------------------------------------------

model StudySession {
  id              String             @id @default(cuid())
  userId          String
  subjectId       String?
  assignmentId    String?
  examId          String?
  quizId          String?
  projectId       String?
  relatedType     RelatedItemType    @default(SUBJECT)
  topicLabel      String // e.g. "ER Diagram" — a snapshot label for display
  scheduledDate   DateTime           @db.Date
  durationMinutes Int
  priorityScore   Float              @default(0)
  priorityLevel   PriorityLevel      @default(MEDIUM)
  status          StudySessionStatus @default(PLANNED)
  source          StudySessionSource @default(AUTO_GENERATED)
  completedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       Subject?       @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  assignment    Assignment?    @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  exam          Exam?          @relation(fields: [examId], references: [id], onDelete: Cascade)
  quiz          Quiz?          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  focusSessions FocusSession[]

  @@index([userId, scheduledDate])
  @@index([subjectId])
  @@index([userId, status])
}

model FocusSession {
  id             String    @id @default(cuid())
  userId         String
  subjectId      String?
  studySessionId String?
  assignmentId   String?
  examId         String?
  quizId         String?
  projectId      String?
  mode           FocusMode @default(POMODORO_25_5)
  plannedMinutes Int
  actualMinutes  Int       @default(0)
  startedAt      DateTime
  endedAt        DateTime?
  completed      Boolean   @default(false)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      Subject?      @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  studySession StudySession? @relation(fields: [studySessionId], references: [id], onDelete: SetNull)
  assignment   Assignment?   @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  exam         Exam?         @relation(fields: [examId], references: [id], onDelete: SetNull)
  quiz         Quiz?         @relation(fields: [quizId], references: [id], onDelete: SetNull)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([subjectId])
}

// ---------------------------------------------------------------------------
// Gamification (Feature 10)
// ---------------------------------------------------------------------------

model Achievement {
  id            String @id @default(cuid())
  key           String @unique // e.g. "streak_7", "hours_100"
  name          String
  description   String
  icon          String // lucide-react icon name
  xpReward      Int    @default(0)
  coinReward    Int    @default(0)
  criteriaType  String // e.g. "STREAK_DAYS", "TOTAL_HOURS", "EXAMS_COMPLETED"
  criteriaValue Float

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

// ---------------------------------------------------------------------------
// Notifications (Feature 11 + 16)
// ---------------------------------------------------------------------------

model Notification {
  id           String           @id @default(cuid())
  userId       String
  type         NotificationType
  title        String
  body         String
  relatedUrl   String?
  read         Boolean          @default(false)
  scheduledFor DateTime?
  sentAt       DateTime?
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, scheduledFor])
}

model NotificationPreference {
  id               String  @id @default(cuid())
  userId           String  @unique
  studyReminders   Boolean @default(true)
  examAlerts       Boolean @default(true)
  assignmentAlerts Boolean @default(true)
  dailySummary     Boolean @default(true)
  weeklySummary    Boolean @default(true)
  streakReminders  Boolean @default(true)
  pushEnabled      Boolean @default(false)
  pushSubscription Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
