# --- Database (Neon Postgres) ---
# Get this from your Neon project dashboard -> Connection Details -> "Prisma" tab.
# Must include ?sslmode=require for Neon.
DATABASE_URL="postgresql://user:password@ep-example-000000.us-east-2.aws.neon.tech/exfocus?sslmode=require"
# Neon's direct (non-pooled) connection, used for migrations. Same host, without "-pooler" and without pgbouncer params.
DIRECT_URL="postgresql://user:password@ep-example-000000.us-east-2.aws.neon.tech/exfocus?sslmode=require"

# --- Auth.js ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-with-generated-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth client (Google Cloud Console -> APIs & Services -> Credentials)
AUTH_GOOGLE_ID="replace-with-google-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-client-secret"

# --- Web Push (generate with `npx web-push generate-vapid-keys`) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# --- Cron (protects /api/cron/notifications from public triggering) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET="replace-with-generated-secret"
